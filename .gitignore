# OS artifacts
.DS_Store
Thumbs.db
desktop.ini

# Editors
.vscode/
.idea/
*.swp
*.swo

# Node (used only by tooling such as SVGO in CI)
node_modules/
npm-debug.log*
package-lock.json

# Python tooling caches
__pycache__/
*.py[cod]
.venv/

# .build/ policy: the generator and validation tooling are tracked on purpose
# (they document how the hero SVGs are produced); every other file in .build/
# is scratch output (test SVGs, preview PNGs, ad-hoc analysis) and never ships.
.build/*
!.build/generate_svgs.py
!.build/optimize_svgs.py
!.build/validate.py
!.build/make_preview.py
!.build/make_final_previews.py

dist/
*.log

# Local secrets — never commit
.env
.env.*
