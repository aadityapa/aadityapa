  },
  "radii": {
    "card": 24,
    "panel": 20,
    "pill": 13.5,
    "faviconTile": 14
  },
  "spacing": {
    "cardPadding": 28,
    "panelPadding": 30,
    "panelGap": 24,
    "infoRowStep": 27,
    "pillGap": 10
  },
  "canvas": {
    "hero": { "width": 1180, "height": 610 },
    "favicon": { "width": 64, "height": 64 }
  },
  "effects": {
    "auroraBlur": 46,
    "glowBlur": 3.2,
    "softShadowBlur": 9,
    "noiseBaseFrequency": 0.85,
    "borderShimmerDuration": "14s",
    "gradientSweepDuration": "9s",
    "scanlineDuration": "11s"
  }
}
